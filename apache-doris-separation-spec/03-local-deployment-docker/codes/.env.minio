# MinIO对象存储配置
# 存算分离模式下使用MinIO模拟S3

# MinIO服务器配置
minio:
  endpoint: minio:9000
  access_key: minioadmin
  secret_key: minioadmin
  bucket: doris-data
  region: us-east-1
  use_https: false

# 缓存配置
cache:
  path: /mnt/disk1/doris_cloud_cache
  size: 50GB
  ttl: 86400

# 计算节点配置
compute:
  fe_servers: fe1:9010,fe2:9010,fe3:9010
  be_addrs: compute1:9050,compute2:9050,compute3:9050
  priority_networks: 172.20.0.0/16
