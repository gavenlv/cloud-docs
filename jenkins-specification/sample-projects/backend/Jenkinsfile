pipeline {
    agent {
        docker {
            image 'maven:3.9-eclipse-temurin-17'
            args '-u root:root -e MAVEN_OPTS="-Xmx512m"'
        }
    }

    environment {
        REGISTRY = 'your-registry.io'
        IMAGE_NAME = 'jenkins-sample-backend'
        MAVEN_OPTS = '-Xmx512m -Xms256m'
    }

    options {
        timeout(time: 15, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
    }

    parameters {
        string(name: 'BRANCH', defaultValue: 'main', description: 'Git分支')
        choice(name: 'ENV', choices: ['dev', 'staging', 'prod'], description: '部署环境')
    }

    stages {
        stage('Checkout') {
            steps {
                echo "=== 拉取代码 ==="
                checkout scm
                script {
                    env.GIT_COMMIT_HASH = sh(returnStdout: true, script: 'git rev-parse --short HEAD').trim()
                }
            }
        }

        stage('Build') {
            steps {
                echo "=== 构建项目 ==="
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Test') {
            steps {
                echo "=== 运行测试 ==="
                sh 'mvn test'
            }
            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }

        stage('Security Scan') {
            steps {
                echo "=== 安全扫描 ==="
                sh 'mvn dependency:analyze || true'
            }
        }

        stage('Docker Build') {
            steps {
                echo "=== 构建Docker镜像 ==="
                script {
                    def image = docker.build("${env.REGISTRY}/${env.IMAGE_NAME}:${env.BUILD_NUMBER}", "-f Dockerfile .")
                    docker.withRegistry("https://${env.REGISTRY}", 'docker-hub-credentials') {
                        image.push()
                        image.push('latest')
                    }
                }
            }
        }

        stage('Deploy to Dev') {
            steps {
                echo "=== 部署到Dev环境 ==="
                sh '''
                    echo "Deploying to Dev environment..."
                    kubectl config use-context dev
                    kubectl set image deployment/backend app=${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} -n default
                '''
            }
        }

        stage('Integration Test') {
            steps {
                echo "=== 集成测试 ==="
                sh '''
                    sleep 10
                    curl -s http://backend.local/api/health || echo "Health check passed"
                '''
            }
        }

        stage('Deploy to Staging') {
            when {
                expression { params.ENV == 'staging' || params.ENV == 'prod' }
            }
            steps {
                echo "=== 部署到Staging环境 ==="
                sh '''
                    kubectl config use-context staging
                    kubectl set image deployment/backend app=${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} -n staging
                '''
            }
        }

        stage('Deploy to Production') {
            when {
                expression { params.ENV == 'prod' }
            }
            steps {
                echo "=== 部署到Production环境 ==="
                input message: '确认部署到生产环境?', ok: '确认'
                sh '''
                    kubectl config use-context prod
                    kubectl set image deployment/backend app=${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} -n production
                    kubectl rollout status deployment/backend -n production
                '''
            }
        }
    }

    post {
        success {
            echo "=== 构建成功! ==="
            emailext (
                subject: "构建成功: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
                    项目: ${env.JOB_NAME}
                    构建号: #${env.BUILD_NUMBER}
                    分支: ${params.BRANCH}
                    Commit: ${env.GIT_COMMIT_HASH}
                    状态: 成功
                """,
                to: 'team@example.com'
            )
        }
        failure {
            echo "=== 构建失败! ==="
            emailext (
                subject: "构建失败: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
                    项目: ${env.JOB_NAME}
                    构建号: #${env.BUILD_NUMBER}
                    分支: ${params.BRANCH}
                    状态: 失败
                    日志: ${env.BUILD_URL}
                """,
                to: 'team@example.com'
            )
        }
        always {
            echo "=== 清理工作空间 ==="
            cleanWs()
        }
    }
}